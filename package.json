{
  "name": "cortex-ai",
  "version": "2.4.0",
  "description": "Synthetic cognition infrastructure for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dream": "tsx src/dream/dream-cycle.ts",
    "ingest": "tsx src/ingestion/ingest-markdown.ts",
    "watch": "tsx src/watcher.ts",
    "mcp": "tsx src/mcp/server.ts",
    "migrate": "tsx scripts/run-migrations.ts",
    "backfill:hippocampal": "tsx scripts/backfill-hippocampal.ts",
    "cogbench:generate": "tsx benchmarks/cogbench/generate.ts",
    "cogbench:run": "tsx benchmarks/cogbench/run.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch"
  },
  "keywords": [
    "ai",
    "agents",
    "memory",
    "cognitive-architecture",
    "hippocampus",
    "dream-cycle",
    "reconsolidation",
    "mcp",
    "pgvector",
    "neuroscience"
  ],
  "author": "Atanasio Juarez <ajuarez@aterna.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/aterna-ai/cortex.git"
  },
  "homepage": "https://github.com/aterna-ai/cortex",
  "bugs": {
    "url": "https://github.com/aterna-ai/cortex/issues"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@neondatabase/serverless": "^0.10.4",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "express": "^4.21.2",
    "gpt-tokenizer": "^2.8.1",
    "openai": "^6.33.0",
    "postgres": "^3.4.8",
    "voyageai": "^0.0.3-1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.12.0",
    "drizzle-kit": "^0.30.4",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
