# CORTEX — Environment Configuration
# Copy this to .env and fill in your values

# ─── Required ─────────────────────────────────────────
# PostgreSQL with pgvector extension (Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@host:5432/cortex?sslmode=require"

# ─── Embeddings (choose one) ─────────────────────────
# Option A: VoyageAI (recommended, best quality)
VOYAGE_API_KEY="pa-..."

# Option B: OpenAI
# OPENAI_API_KEY="sk-..."

# ─── LLM for Dream Summaries + Entity Extraction ─────
# Used for abstractive dream consolidation and semantic NER
# Default provider: anthropic
ANTHROPIC_API_KEY="sk-ant-..."
# CORTEX_LLM_PROVIDER="anthropic"  # anthropic | openai | openrouter
# CORTEX_LLM_MODEL=""              # auto-detected per provider

# ─── Optional: LLM-based Entity Extraction ───────────
# Set to "true" to use Claude for semantic NER during ingest
# Costs ~$0.001 per ingest call. Default: regex-only (free)
# CORTEX_LLM_ENTITIES="true"

# ─── Optional: Workspace ─────────────────────────────
# CORTEX_WORKSPACE="/path/to/agent/workspace"

# ─── Optional: Ollama (local embeddings) ─────────────
# OLLAMA_URL="http://localhost:11434"
# EMBEDDING_PROVIDER="ollama"
